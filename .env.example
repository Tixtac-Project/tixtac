# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# Database (Neon PostgreSQL)
# https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.ap-southeast-1.aws.neon.tech/tixtac?sslmode=require

# Message Queue (CloudAMQP)
# https://customer.cloudamqp.com → Instance → AMQP Details
CLOUDAMQP_URL=amqps://user:password@rattlesnake.rmq.cloudamqp.com/vhost

# Redis (Upstash Redis)
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Auth
# Sinh random: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-string
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=example@gmail.com
APP_URL=http://localhost:5173

# Business Config
SEAT_LOCK_DURATION=600          # Thời gian giữ chỗ (giây). 600 = 10 phút
MAX_CONCURRENT_USERS=200        # Ngưỡng kích hoạt Virtual Queue
ACCESS_TOKEN_DURATION=300       # Thời hạn access token sau hàng chờ (giây). 300 = 5 phút

# Override
SEAT_LOCK_DURATION=600         # Thời gian nhả ghế (giây)
# MAX_CONCURRENT_USERS=3       # Giới hạn người dùng đồng thời (để demo Virtual Queue)
