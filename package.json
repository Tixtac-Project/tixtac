{
  "name": "tixtac",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . --experimental-cli",
    "db:push": "drizzle-kit push",
    "db:seed": "bun src/lib/server/db/seed.ts && bun src/lib/server/db/seed-tickets.ts && bun src/lib/server/db/seed-staff.ts",
    "db:migrate": "drizzle-kit migrate",
    "test:race": "bun run scripts/reset-db.ts && bun run tests/race-condition.test.ts",
    "db:reset": "bun run scripts/reset-db.ts",
    "email:dev": "bse dev"
  },
  "devDependencies": {
    "@better-svelte-email/cli": "^2.0.0",
