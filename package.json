{
  "name": "tixtac",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . --experimental-cli",
    "db:push": "drizzle-kit push",
    "db:seed": "bun src/lib/server/db/seed.ts",
    "test:race": "bun run scripts/reset-test-data.ts && bun run scripts/test-race.ts",
    "test:race:reset": "bun run scripts/reset-test-data.ts",
    "test:race:demo": "bun run scripts/demo-race.ts"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.61.5",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@prettier/plugin-oxc": "^0.1.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/amqplib": "^0.10.8",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "layerchart": "^2.0.0-next.58",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@fontsource-variable/lexend": "^5.2.11",
    "@tanstack/table-core": "^8.21.3",
    "amqplib": "^1.0.3",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-autoplay": "^8.6.0",
    "isomorphic-dompurify": "^3.10.0",
    "jose": "^6.2.2",
    "konva": "^10.2.5",
    "lucide-svelte": "^1.0.1",
    "overtype": "^2.3.5",
    "pg": "^8.20.0",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-konva": "^1.0.1",
    "zod": "^4.3.6"
